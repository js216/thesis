\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Magnetic fields along the central axis of a single layer cylindrical magnetic shield, constructed as a 14"-diameter PVC tube wrapped with 12 turns of 22~$\mu $m-thick metglas ($\mu \approx 70,000$). Length of shielded region is approx.\ 2.5~m. The dotted lines indicate the position of the overlaps between the eight circumferential wraps of metglas; dashed lines represent the end of the metglas segments; solid lines show end of plastic tube. The center of the shielded region is the dotted line just right of 200~cm.\textit  {\textbf  {a.}} Before degaussing (difficult to predict theoretically). \textit  {\textbf  {b.}} After degaussing. Simple model (eqn.~\ref {singlelayer}) would predict 0.2~mG and 4~mG for the transverse and longitudinal components.\relax }}{82}{figure.caption.55}\protected@file@percent }
\newlabel{beforeafter}{{19}{82}{Magnetic fields along the central axis of a single layer cylindrical magnetic shield, constructed as a 14"-diameter PVC tube wrapped with 12 turns of 22~$\mu $m-thick metglas ($\mu \approx 70,000$). Length of shielded region is approx.\ 2.5~m. The dotted lines indicate the position of the overlaps between the eight circumferential wraps of metglas; dashed lines represent the end of the metglas segments; solid lines show end of plastic tube. The center of the shielded region is the dotted line just right of 200~cm.\part {a} Before degaussing (difficult to predict theoretically). \part {b} After degaussing. Simple model (eqn.~\ref {singlelayer}) would predict 0.2~mG and 4~mG for the transverse and longitudinal components.\relax }{figure.caption.55}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Magnetization curves, found by numerically integrating eqn~\ref {jiles_atherton_eqn} with the parameters given in the figure. \textit  {\textbf  {Left.}} Degaussing: naive picture, an oscillating applied field $H_0$ with no offset decreases till the material spirals into the origin of the $M$--$H$ or $B$--$H$ space (demagnetization). All the \emph  {minor loops} are centered around the origin. See end of section \ref {degaussing_hysteresis} regarding the negative slope. \textit  {\textbf  {Right.}} Degaussing means applying the oscillating field with decaying amplitude in the presence of an offset (lab) field. As the amplitude of the oscillations goes to zero, the material settles on a point on the \emph  {anhysteretic curve} (dashed line). Notice how the anhysteretic curve is much steeper than the minor loops, implying a greater effective permeability. See also Fig.~\ref {hysteresis} for curves measured on metglas.\relax }}{83}{figure.caption.56}\protected@file@percent }
\newlabel{degaussing_theory}{{20}{83}{Magnetization curves, found by numerically integrating eqn~\ref {jiles_atherton_eqn} with the parameters given in the figure. \part {Left} Degaussing: naive picture, an oscillating applied field $H_0$ with no offset decreases till the material spirals into the origin of the $M$--$H$ or $B$--$H$ space (demagnetization). All the \emph {minor loops} are centered around the origin. See end of section \ref {degaussing_hysteresis} regarding the negative slope. \part {Right} Degaussing means applying the oscillating field with decaying amplitude in the presence of an offset (lab) field. As the amplitude of the oscillations goes to zero, the material settles on a point on the \emph {anhysteretic curve} (dashed line). Notice how the anhysteretic curve is much steeper than the minor loops, implying a greater effective permeability. See also Fig.~\ref {hysteresis} for curves measured on metglas.\relax }{figure.caption.56}{}}
