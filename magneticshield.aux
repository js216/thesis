\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Magnetic fields along the central axis of a single layer cylindrical magnetic shield, constructed as a 14"-diameter PVC tube wrapped with 12 turns of 22~$\mu $m-thick metglas ($\mu \approx 70,000$). Length of shielded region is approx.\ 2.5~m. The dotted lines indicate the position of the overlaps between the eight circumferential wraps of metglas; dashed lines represent the end of the metglas segments; solid lines show end of plastic tube. The center of the shielded region is the dotted line just right of 200~cm.\textit  {\textbf  {a.}} Before degaussing (difficult to predict theoretically). \textit  {\textbf  {b.}} After degaussing. Simple model (eqn.~\ref  {singlelayer}) would predict 0.2~mG and 4~mG for the transverse and longitudinal components.\relax }}{80}{figure.caption.55}\protected@file@percent }
\newlabel{beforeafter}{{19}{80}{Magnetic fields along the central axis of a single layer cylindrical magnetic shield, constructed as a 14"-diameter PVC tube wrapped with 12 turns of 22~$\mu $m-thick metglas ($\mu \approx 70,000$). Length of shielded region is approx.\ 2.5~m. The dotted lines indicate the position of the overlaps between the eight circumferential wraps of metglas; dashed lines represent the end of the metglas segments; solid lines show end of plastic tube. The center of the shielded region is the dotted line just right of 200~cm.\part {a} Before degaussing (difficult to predict theoretically). \part {b} After degaussing. Simple model (eqn.~\ref {singlelayer}) would predict 0.2~mG and 4~mG for the transverse and longitudinal components.\relax }{figure.caption.55}{}}
