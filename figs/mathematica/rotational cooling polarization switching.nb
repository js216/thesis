             {"0", "0", "0", "0", "0", "0", "0", "0", "0"}
            }], ")"}], "/", "6"}], ",", "0"}], "]"}]}], "\[IndentingNewLine]",
       "]"}], ",", 
     RowBox[{"DMVariables", "[", "system", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "160"}], "}"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]}], "Input",
