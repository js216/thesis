Cell[CellGroupData[{

Cell["Branching ratios", "Subsubsection",
 CellChangeTimes->{{3.7664000418412576`*^9, 
  3.76640004339282*^9}},ExpressionUUID->"f76986b6-55fe-4451-874f-\
1391aaf76640"],

Cell["\<\
Take the expression for unnormalized matrix elements from Hutzler\
\[CloseCurlyQuote]s eqn 2.57:\
\>", "Text",
 CellChangeTimes->{{3.76639914766411*^9, 
  3.7663992007204075`*^9}},ExpressionUUID->"74195c24-1d16-41be-860b-\
a7fb0c223f08"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ME", "[", 
   RowBox[{
   "J_", ",", "M_", ",", "\[CapitalOmega]_", ",", "Jp_", ",", "Mp_", ",", 
    "\[CapitalOmega]p_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", "J"}], "+", "1"}], ")"}], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", "Jp"}], "+", "1"}], ")"}], 
   SuperscriptBox[
    RowBox[{"ThreeJSymbol", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"J", ",", 
        RowBox[{"-", "\[CapitalOmega]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"\[CapitalOmega]", "-", "\[CapitalOmega]p"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Jp", ",", "\[CapitalOmega]p"}], "}"}]}], "]"}], "2"], 
   SuperscriptBox[
    RowBox[{"ThreeJSymbol", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"J", ",", 
        RowBox[{"-", "M"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"M", "-", "Mp"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Jp", ",", "Mp"}], "}"}]}], "]"}], "2"]}]}]], "Input",
 CellChangeTimes->{{3.7663990266045604`*^9, 3.766399138034034*^9}},
 CellLabel->"In[76]:=",ExpressionUUID->"8e65a01d-8f8c-438b-983a-26f1b43de4f2"],

Cell["Then the branching ratios are", "Text",
 CellChangeTimes->{{3.766399186816293*^9, 
  3.766399209488282*^9}},ExpressionUUID->"57efb12c-9c1e-48bd-9c47-\
f87b122a7b8c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"b2", "=", 
   RowBox[{"Sum", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ME", "[", 
      RowBox[{"2", ",", "M", ",", "0", ",", "1", ",", "Mp", ",", "1"}], "]"}],
      ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"M", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"Mp", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b0", "=", 
   RowBox[{"Sum", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ME", "[", 
      RowBox[{"0", ",", "M", ",", "0", ",", "1", ",", "Mp", ",", "1"}], "]"}],
      ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"M", ",", "0", ",", "0"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"Mp", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.766399219092382*^9, 3.7663992279042163`*^9}, {
  3.766399329584453*^9, 3.766399397904248*^9}, {3.7663994437607517`*^9, 
  3.7663994967686296`*^9}, {3.766399876033891*^9, 3.766399877794259*^9}, {
  3.7663999378905687`*^9, 3.7663999623848705`*^9}, {3.7664013103391285`*^9, 
  3.76640134249833*^9}},
 CellLabel->"In[77]:=",ExpressionUUID->"c815bebe-3316-48aa-92b9-0b82399f9baa"],

