Cell[CellGroupData[{

Cell["Level structure", "Subsubsection",
 CellChangeTimes->{{3.7664000610724363`*^9, 
  3.766400064096634*^9}},ExpressionUUID->"0dac2d0a-3f88-4646-8441-\
3c8723cedd88"],

Cell[TextData[{
 "Consider a model where a laser drives transitions between the electronic \
ground and excited states. The excited state has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"J", "'"}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "e2b8c075-704a-4416-9350-553134c432b5"],
 " and has a lifetime of about ",
 Cell[BoxData[
  FormBox[
   RowBox[{"100", " ", "ns"}], TraditionalForm]],ExpressionUUID->
  "773f9e08-2829-4d23-a415-4128e85ffc9f"],
 ". In the ground state, only decays/transitions to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "22f2a95f-dbba-452a-97fa-8db7426392e1"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", "=", "2"}], TraditionalForm]],ExpressionUUID->
  "73998abf-5c7d-4636-8977-52fa2fa2d6b2"],
 " are allowed. \n\n",
