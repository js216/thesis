       RowBox[{"\"\<e\>\"", ",", 
        RowBox[{"NaturalWidth", "\[Rule]", "\[CapitalGamma]"}], ",", 
        RowBox[{
         RowBox[{"BranchingRatio", "[", "0", "]"}], "\[Rule]", 
         RowBox[{"2", "/", "3"}]}], ",", 
        RowBox[{
         RowBox[{"BranchingRatio", "[", "2", "]"}], "\[Rule]", 
         RowBox[{"1", "/", "3"}]}], ",", 
