Cell["Compare with the Weiss model (black dashed line):", "Text",
 CellChangeTimes->{{3.89156066865051*^9, 3.891560673351553*^9}, {
  3.89156081788243*^9, 3.8915608188562803`*^9}, {3.8915612893450813`*^9, 
  3.891561291163101*^9}},ExpressionUUID->"d0794fa6-2db8-4648-b589-\
c0f13cc481ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"weiss", "=", 
   RowBox[{"Plot", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"M", "/.", 
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "[", 
            FractionBox[
             RowBox[{"H", "+", 
              RowBox[{"\[Alpha]", " ", "M"}]}], "a"], "]"}], "/.", "params"}],
           ")"}], "-", "M"}], ",", 
        RowBox[{"{", 
         RowBox[{"M", ",", "1"}], "}"}]}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"H", ",", "Hi0", ",", "Hf0"}], "}"}], "/.", "params"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotTheme", "\[Rule]", "\"\<Monochrome\>\""}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<H [a/\!\(\*SubscriptBox[\(\[Mu]\), \(0\)]\)]\>\"", ",", 
        "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\) [a/\[Mu]0]\>\""}], "}"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"BaseStyle", "\[Rule]", 
      RowBox[{"FontSize", "\[Rule]", "16"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Black", ",", "Dashed"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"weiss", ",", "lp"}], "]"}]}], "Input",
