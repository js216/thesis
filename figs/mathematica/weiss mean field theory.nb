Cell[BoxData[
 RowBox[{"(", 
  RowBox[{"M", "/.", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"k", " ", 
          RowBox[{
           RowBox[{"M", "'"}], "[", "H", "]"}]}], "\[Equal]", 
         RowBox[{
          RowBox[{"L", "[", 
           FractionBox[
            RowBox[{"H", "+", 
             RowBox[{"\[Alpha]", " ", 
              RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
          RowBox[{"M", "[", "H", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"M", "[", "Hi", "]"}], "\[Equal]", "Mi"}]}], "}"}], ",", 
      "\[IndentingNewLine]", "M", ",", 
      RowBox[{"{", 
       RowBox[{"H", ",", "4", ",", "3"}], "}"}]}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ")"}]], "Input",
