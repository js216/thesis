Cell["Initial loop:", "Text",
 CellChangeTimes->{{3.8915314769762897`*^9, 
  3.891531478400857*^9}},ExpressionUUID->"3ff39223-bd79-4397-8a49-\
b5da1c537dff"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Mforward", "[", "H_", "]"}], "=", 
   RowBox[{
    RowBox[{"M", "[", "H", "]"}], "/.", 
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"k", " ", 
          RowBox[{
           RowBox[{"M", "'"}], "[", "H", "]"}]}], "\[Equal]", 
         RowBox[{
          RowBox[{"L", "[", 
           FractionBox[
            RowBox[{"H", "+", 
             RowBox[{"\[Alpha]", " ", 
              RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
          RowBox[{"M", "[", "H", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"M", "[", "Hi", "]"}], "\[Equal]", "Mi"}]}], "}"}], ",", 
      "\[IndentingNewLine]", "M", ",", 
      RowBox[{"{", 
       RowBox[{"H", ",", "Hi", ",", "Hf"}], "}"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pf0", "=", 
   RowBox[{"Plot", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"Mforward", "[", "H", "]"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"H", ",", "Hi", ",", "Hf"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Hi", ",", "Hf"}], "}"}], ",", "All"}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotTheme", "\[Rule]", "\"\<Monochrome\>\""}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<H [a/\!\(\*SubscriptBox[\(\[Mu]\), \(0\)]\)]\>\"", ",", 
        "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\) [a/\[Mu]0]\>\""}], "}"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"BaseStyle", "\[Rule]", 
      RowBox[{"FontSize", "\[Rule]", "16"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Mbackward", "[", "H_", "]"}], "=", 
   RowBox[{
    RowBox[{"M", "[", "H", "]"}], "/.", 
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", "k"}], " ", 
          RowBox[{
           RowBox[{"M", "'"}], "[", "H", "]"}]}], "\[Equal]", 
         RowBox[{
          RowBox[{"L", "[", 
           FractionBox[
            RowBox[{"H", "+", 
             RowBox[{"\[Alpha]", " ", 
              RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
          RowBox[{"M", "[", "H", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"M", "[", "Hf", "]"}], "\[Equal]", 
         RowBox[{"Mforward", "[", "Hf", "]"}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", "M", ",", 
      RowBox[{"{", 
       RowBox[{"H", ",", "Hf", ",", "Hi"}], "}"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pb0", "=", 
   RowBox[{"Plot", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"Mbackward", "[", "H", "]"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"H", ",", "Hi", ",", "Hf"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Hi", ",", "Hf"}], "}"}], ",", "All"}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotTheme", "\[Rule]", "\"\<Monochrome\>\""}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<H [a/\!\(\*SubscriptBox[\(\[Mu]\), \(0\)]\)]\>\"", ",", 
        "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\) [a/\[Mu]0]\>\""}], "}"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"BaseStyle", "\[Rule]", 
      RowBox[{"FontSize", "\[Rule]", "16"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"pf0", ",", "pb0"}], "]"}]}], "Input",
 CellChangeTimes->{{3.8915313051602387`*^9, 3.8915313207594957`*^9}, {
