   3.8915632847116203`*^9, 3.89156329844592*^9}},
 CellLabel->
  "In[128]:=",ExpressionUUID->"b48c06fd-8cc4-4063-9037-ed4898f6a3aa"],

Cell["Define a function to plot a curve:", "Text",
 CellChangeTimes->{{3.89155667364997*^9, 
  3.891556680064127*^9}},ExpressionUUID->"4097010c-c625-4e81-81a6-\
ff6b0d700fae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p", "[", "M_", "]"}], ":=", 
  RowBox[{"Plot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{"M", "[", "H", "]"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"H", ",", 
      RowBox[{
       RowBox[{"M", "[", "\"\<Domain\>\"", "]"}], "\[LeftDoubleBracket]", 
       RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
      RowBox[{
       RowBox[{"M", "[", "\"\<Domain\>\"", "]"}], "\[LeftDoubleBracket]", 
       RowBox[{"1", ",", "2"}], "\[RightDoubleBracket]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"M", "[", "\"\<Domain\>\"", "]"}], "\[LeftDoubleBracket]", 
        "1", "\[RightDoubleBracket]"}], ",", "All"}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotTheme", "\[Rule]", "\"\<Monochrome\>\""}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<H [a/\!\(\*SubscriptBox[\(\[Mu]\), \(0\)]\)]\>\"", ",", 
       "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\) [a/\[Mu]0]\>\""}], "}"}]}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{"BaseStyle", "\[Rule]", 
     RowBox[{"FontSize", "\[Rule]", "16"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"Thickness", "[", "0.002", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8915345575502896`*^9, 3.891534561658042*^9}, {
   3.8915346727754316`*^9, 3.891534674303276*^9}, {3.8915347150051975`*^9, 
   3.8915347158764267`*^9}, {3.8915347593035975`*^9, 
   3.8915348214528847`*^9}, {3.891534888942583*^9, 3.8915349005260305`*^9}, {
