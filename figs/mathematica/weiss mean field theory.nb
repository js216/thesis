Cell[BoxData[
 RowBox[{
  RowBox[{"p", "[", 
   RowBox[{"M_", ",", "params_"}], "]"}], ":=", 
  RowBox[{"Plot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"M", "[", 
       RowBox[{
        SuperscriptBox["10", "3"], "H"}], "]"}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"Ms", "/.", "params"}], ")"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"H", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"M", "[", "\"\<Domain\>\"", "]"}], "\[LeftDoubleBracket]", 
        RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], "/", 
       SuperscriptBox["10", "3"]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"M", "[", "\"\<Domain\>\"", "]"}], "\[LeftDoubleBracket]", 
        RowBox[{"1", ",", "2"}], "\[RightDoubleBracket]"}], "/", 
       SuperscriptBox["10", "3"]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"M", "[", "\"\<Domain\>\"", "]"}], "\[LeftDoubleBracket]", 
           RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], "/", 
          SuperscriptBox["10", "3"]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"M", "[", "\"\<Domain\>\"", "]"}], "\[LeftDoubleBracket]", 
           RowBox[{"1", ",", "2"}], "\[RightDoubleBracket]"}], "/", 
          SuperscriptBox["10", "3"]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotTheme", "\[Rule]", "\"\<Monochrome\>\""}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<H [kA/m]\>\"", ",", 
       "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\)\>\""}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"BaseStyle", "\[Rule]", 
     RowBox[{"FontSize", "\[Rule]", "16"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"Thickness", "[", "0.002", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8915345575502896`*^9, 3.891534561658042*^9}, {
