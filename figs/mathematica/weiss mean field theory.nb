Cell[CellGroupData[{

Cell["Jiles-Atherton", "Subsubsection",
 CellChangeTimes->{{3.8915281714196434`*^9, 
  3.8915281760225077`*^9}},ExpressionUUID->"af29a0e5-6430-42e0-8b70-\
c55a1d1f1ab5"],

Cell["The Langevin function is", "Text",
 CellChangeTimes->{{3.891520943741767*^9, 
  3.891520950223053*^9}},ExpressionUUID->"cc2894bf-957d-4ae3-b8bc-\
d3e9d37c939f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"L", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Coth", "[", "x", "]"}], "-", 
   FractionBox["1", "x"]}]}]], "Input",
 CellLabel->
  "4/26/23 15:51:10 \
In[1]:=",ExpressionUUID->"125dd7df-e809-4873-af75-5f4d67b589cd"],

Cell["\<\
A hysteresis loop is found by numerically integrating the Jiles-Atherton \
differential equation for the forward and backward motion:\
\>", "Text",
 CellChangeTimes->{{3.891528375529499*^9, 3.891528386433187*^9}, {
  3.891529764831873*^9, 
  3.891529775491652*^9}},ExpressionUUID->"1f295ee3-559b-4865-9857-\
ba6c53cec551"],

Cell[BoxData[
 RowBox[{
  RowBox[{"loop", "[", 
   RowBox[{
   "k_", ",", "a_", ",", "\[Alpha]_", ",", "Hi_", ",", "Hf_", ",", "Mi_", ",",
     "Mf_"}], "]"}], ":=", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"M", "[", "H", "]"}], "/.", 
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"k", " ", 
           RowBox[{
            RowBox[{"M", "'"}], "[", "H", "]"}]}], "\[Equal]", 
          RowBox[{
           RowBox[{"L", "[", 
            FractionBox[
             RowBox[{"H", "+", 
              RowBox[{"\[Alpha]", " ", 
               RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
           RowBox[{"M", "[", "H", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{"M", "[", "Hi", "]"}], "\[Equal]", "Mi"}]}], "}"}], ",", 
       "\[IndentingNewLine]", "M", ",", 
       RowBox[{"{", 
        RowBox[{"H", ",", "Hi", ",", "Hf"}], "}"}]}], "]"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"M", "[", "H", "]"}], "/.", 
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"-", "k"}], " ", 
           RowBox[{
            RowBox[{"M", "'"}], "[", "H", "]"}]}], "\[Equal]", 
          RowBox[{
           RowBox[{"L", "[", 
            FractionBox[
             RowBox[{"H", "+", 
              RowBox[{"\[Alpha]", " ", 
               RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
           RowBox[{"M", "[", "H", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{"M", "[", "Hf", "]"}], "\[Equal]", "Mf"}]}], "}"}], ",", 
       "\[IndentingNewLine]", "M", ",", 
       RowBox[{"{", 
        RowBox[{"H", ",", "Hf", ",", "Hi"}], "}"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "}"}]}]], "Input",
 CellChangeTimes->{{3.8915307402973623`*^9, 3.8915307506070733`*^9}, {
  3.891530783377945*^9, 3.891530812856743*^9}, {3.8915309340522594`*^9, 
  3.8915310284546385`*^9}, {3.8915310841276197`*^9, 3.8915311348933673`*^9}, {
  3.89153117798221*^9, 3.891531241759165*^9}},
 CellLabel->
  "4/26/23 15:54:01 \
In[13]:=",ExpressionUUID->"119f1f73-e514-4aba-b6c5-d248b92217b0"],

