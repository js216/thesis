Cell[TextData[{
 "Giving M in units of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "s"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "d408e406-a7d8-40a0-ac3f-89129f93acc4"],
 " and parameter ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "9642b6a3-fb20-4e2e-a71e-cc55a7cbb640"],
 " in units of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "0"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "06e09c68-4ba2-4b45-985f-82188ab1b09a"],
 Cell[BoxData[
  FormBox[
  Cell["",ExpressionUUID->"c770ff85-1cf7-436e-8302-8185695ef1a9"], 
   TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "3c159c44-8c21-4784-b406-a9f3b39e42e8"],
 ", we can solve the Weiss mean field equation:"
}], "Text",
 CellChangeTimes->{{3.8915219013072014`*^9, 
  3.8915219356704783`*^9}},ExpressionUUID->"14c1b06d-b50d-4630-bf0a-\
c0d0a429fbdc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"plot", "=", 
  RowBox[{"Plot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"L", "[", 
        RowBox[{"H", "/", "a"}], "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{"a", "\[Rule]", "1"}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"M", "/.", 
       RowBox[{"FindRoot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"L", "[", 
             FractionBox[
              RowBox[{"H", "+", 
               RowBox[{"\[Alpha]", " ", "M"}]}], "a"], "]"}], "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"a", "\[Rule]", "1"}], ",", 
              RowBox[{"\[Alpha]", "\[Rule]", "1"}]}], "}"}]}], ")"}], "-", 
          "M"}], ",", 
         RowBox[{"{", 
          RowBox[{"M", ",", "1"}], "}"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"M", "/.", 
       RowBox[{"FindRoot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"L", "[", 
             FractionBox[
              RowBox[{"H", "+", 
               RowBox[{"\[Alpha]", " ", "M"}]}], "a"], "]"}], "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"a", "\[Rule]", "1"}], ",", 
              RowBox[{"\[Alpha]", "\[Rule]", "3"}]}], "}"}]}], ")"}], "-", 
          "M"}], ",", 
         RowBox[{"{", 
          RowBox[{"M", ",", "1"}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"H", ",", 
      RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotLegends", "\[Rule]", 
     RowBox[{"Placed", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "\"\<\[Alpha]=0\>\"", ",", "\"\<\[Alpha]=1\>\"", ",", 
         "\"\<\[Alpha]=3\>\""}], "}"}], ",", "Top"}], "]"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotTheme", "\[Rule]", "\"\<Monochrome\>\""}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<H [a/\!\(\*SubscriptBox[\(\[Mu]\), \(0\)]\)]\>\"", ",", 
       "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\) [a/\[Mu]0]\>\""}], "}"}]}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{"BaseStyle", "\[Rule]", 
     RowBox[{"FontSize", "\[Rule]", "16"}]}]}], "\[IndentingNewLine]", 
