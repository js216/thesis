Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Mnext", "[", 
    RowBox[{"Mprev_", ",", "\[Delta]_"}], "]"}], ":=", 
   RowBox[{"M", "/.", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"-", "1"}], ")"}], 
            RowBox[{"\[Delta]", "+", "1"}]], " ", "k", " ", 
           RowBox[{
            RowBox[{"M", "'"}], "[", "H", "]"}]}], "\[Equal]", 
          RowBox[{
           RowBox[{"L", "[", 
            FractionBox[
             RowBox[{"H", "+", 
              RowBox[{"\[Alpha]", " ", 
               RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
           RowBox[{"M", "[", "H", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{"M", "[", 
           RowBox[{
            RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
            "\[LeftDoubleBracket]", 
            RowBox[{"1", ",", "\[Delta]"}], "\[RightDoubleBracket]"}], "]"}], 
          "\[Equal]", 
          RowBox[{"Mprev", "[", 
           RowBox[{
            RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
            "\[LeftDoubleBracket]", 
            RowBox[{"1", ",", "\[Delta]"}], "\[RightDoubleBracket]"}], 
           "]"}]}]}], "}"}], ",", "\[IndentingNewLine]", "M", ",", 
       RowBox[{"{", 
        RowBox[{"H", ",", 
         RowBox[{
          RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
          "\[LeftDoubleBracket]", 
          RowBox[{"1", ",", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"\[Delta]", "+", "1"}], ",", "2"}], "]"}], "+", "1"}]}],
           "\[RightDoubleBracket]"}], ",", 
         RowBox[{
          RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
          "\[LeftDoubleBracket]", 
          RowBox[{"1", ",", "\[Delta]"}], "\[RightDoubleBracket]"}]}], 
        "}"}]}], "\[IndentingNewLine]", "]"}], "\[LeftDoubleBracket]", 
     RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}]}], ";"}]], "Input",
