Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Hi0", "\[Rule]", 
      RowBox[{"-", "3000"}]}], ",", 
     RowBox[{"Hf0", "\[Rule]", "3000"}], ",", 
     RowBox[{"dH", "\[Rule]", "0"}], ",", 
     RowBox[{"Mi0", "\[Rule]", 
      RowBox[{
       RowBox[{"-", "1.24"}], " ", 
       SuperscriptBox["10", "6"]}]}], ",", 
     RowBox[{"Ms", "\[Rule]", 
      RowBox[{"1.6", " ", 
       SuperscriptBox["10", "6"]}]}], ",", 
     RowBox[{"c", "\[Rule]", "1.2"}], ",", 
     RowBox[{"a", "\[Rule]", "1100"}], ",", 
     RowBox[{"\[Alpha]", "\[Rule]", 
      RowBox[{"1.6", " ", 
       SuperscriptBox["10", 
        RowBox[{"-", "3"}]]}]}], ",", 
     RowBox[{"k", "\[Rule]", "400"}], ",", 
     RowBox[{"decay", "\[Rule]", "0.8"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ntimes", "=", "30"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Marr", " ", "=", " ", 
    RowBox[{"NestList", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"MMnext", "[", 
          RowBox[{
           RowBox[{
           "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",", 
           RowBox[{
            RowBox[{
            "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "+", 
