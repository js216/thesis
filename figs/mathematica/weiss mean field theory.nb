Cell["\<\
Define a function that gives the next curve (changes direction of H change, \
and reduces the range of H):\
\>", "Text",
 CellChangeTimes->{{3.891556646150468*^9, 
  3.8915566707090683`*^9}},ExpressionUUID->"9431614f-2112-4b59-9ae0-\
2ea04e0daa95"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Mnext", "[", 
    RowBox[{"Mprev_", ",", "\[Delta]_", ",", "params_"}], "]"}], ":=", 
   RowBox[{"M", "/.", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"-", "1"}], ")"}], "\[Delta]"], " ", "k", 
             RowBox[{"(", " ", 
              RowBox[{
               RowBox[{
                RowBox[{"M", "'"}], "[", "H", "]"}], "/", 
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 RowBox[{"\[Alpha]", " ", 
                  RowBox[{
                   RowBox[{"M", "'"}], "[", "H", "]"}]}]}], ")"}]}], ")"}]}], 
            "\[Equal]", 
            RowBox[{
             RowBox[{"L", "[", 
              FractionBox[
               RowBox[{"H", "+", 
                RowBox[{"\[Alpha]", " ", 
                 RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
             RowBox[{"M", "[", "H", "]"}]}]}], ")"}], "/.", "params"}], ",", 
         RowBox[{
          RowBox[{"M", "[", 
           RowBox[{
            RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
            "\[LeftDoubleBracket]", 
            RowBox[{"1", ",", 
             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{"\[Delta]", ",", "2"}], "]"}], "+", "1"}]}], 
            "\[RightDoubleBracket]"}], "]"}], "\[Equal]", 
          RowBox[{"Mprev", "[", 
           RowBox[{
            RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
            "\[LeftDoubleBracket]", 
            RowBox[{"1", ",", 
             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{"\[Delta]", ",", "2"}], "]"}], "+", "1"}]}], 
            "\[RightDoubleBracket]"}], "]"}]}]}], "}"}], ",", 
       "\[IndentingNewLine]", "M", ",", 
       RowBox[{"{", 
        RowBox[{"H", ",", 
         RowBox[{
          RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
          "\[LeftDoubleBracket]", 
          RowBox[{"1", ",", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"\[Delta]", ",", "2"}], "]"}], "+", "1"}]}], 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"decay", "*", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
                "\[LeftDoubleBracket]", 
                RowBox[{"1", ",", 
                 RowBox[{
                  RowBox[{"Mod", "[", 
                   RowBox[{
                    RowBox[{"\[Delta]", "+", "1"}], ",", "2"}], "]"}], "+", 
                  "1"}]}], "\[RightDoubleBracket]"}], "-", "dH"}], ")"}]}], 
            "+", "dH"}], ")"}], "/.", "params"}]}], "}"}]}], 
      "\[IndentingNewLine]", "]"}], "\[LeftDoubleBracket]", 
     RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.891534495745146*^9, 3.8915345295491085`*^9}, {
   3.8915345804506083`*^9, 3.891534582474359*^9}, {3.891534619083971*^9, 
   3.8915346659191017`*^9}, {3.891534704609727*^9, 3.8915347432188387`*^9}, {
   3.8915349195027757`*^9, 3.8915349320121365`*^9}, {3.891534969746174*^9, 
   3.8915349802963886`*^9}, {3.8915350550426545`*^9, 
   3.8915350845222664`*^9}, {3.891535403314401*^9, 3.891535536990264*^9}, {
   3.891535586480873*^9, 3.891535646051313*^9}, {3.891553945751973*^9, 
   3.89155394587031*^9}, {3.891554146351869*^9, 3.8915541471005373`*^9}, {
   3.891554356030612*^9, 3.891554357180169*^9}, {3.8915544330742493`*^9, 
   3.891554435707096*^9}, {3.891554540866839*^9, 3.891554540903429*^9}, {
   3.891554927294958*^9, 3.891554942914608*^9}, 3.891555132129871*^9, {
   3.891556144422402*^9, 3.8915561462869864`*^9}, {3.891556956674574*^9, 
   3.891556966710177*^9}, {3.891557268877461*^9, 3.891557283636257*^9}, {
