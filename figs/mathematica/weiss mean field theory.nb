Cell["\<\
Define a function that gives the next curve (changes direction of H change, \
and reduces the range of H):\
\>", "Text",
 CellChangeTimes->{{3.891556646150468*^9, 
  3.8915566707090683`*^9}},ExpressionUUID->"7192f6d7-9d0a-4c6c-a42b-\
46c0e639678c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MMnext", "[", 
    RowBox[{"Mprev_", ",", "\[Delta]_", ",", "params_"}], "]"}], ":=", 
   RowBox[{"M", "/.", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"M", "'"}], "[", "H", "]"}], "\[Equal]", 
            RowBox[{
             RowBox[{
              FractionBox["1", 
               RowBox[{"1", "+", "c"}]], 
              FractionBox[
               RowBox[{
                RowBox[{"Ms", " ", 
                 RowBox[{"L", "[", 
                  FractionBox[
                   RowBox[{"H", "+", 
                    RowBox[{"\[Alpha]", " ", 
                    RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}]}], "-", 
                RowBox[{"M", "[", "H", "]"}]}], 
               RowBox[{
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{"-", "1"}], ")"}], "\[Delta]"], "k"}], "-", 
                RowBox[{"\[Alpha]", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"Ms", " ", 
                    RowBox[{"L", "[", 
                    FractionBox[
                    RowBox[{"H", "+", 
                    RowBox[{"\[Alpha]", " ", 
                    RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}]}], "-", 
                   RowBox[{"M", "[", "H", "]"}]}], ")"}]}]}]]}], "+", 
             RowBox[{
              FractionBox["c", 
               RowBox[{"1", "+", "c"}]], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Ms", " ", 
                 RowBox[{
                  RowBox[{"L", "'"}], "[", 
                  FractionBox[
                   RowBox[{"H", "+", 
                    RowBox[{"\[Alpha]", " ", 
                    RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], 
                 RowBox[{"(", 
                  FractionBox[
                   RowBox[{"1", "+", 
                    RowBox[{"\[Alpha]", " ", 
                    RowBox[{
                    RowBox[{"M", "'"}], "[", "H", "]"}]}]}], "a"], ")"}]}], 
                "-", 
                RowBox[{
                 RowBox[{"M", "'"}], "[", "H", "]"}]}], ")"}]}]}]}], ")"}], "/.",
           "params"}], ",", 
         RowBox[{
          RowBox[{"M", "[", 
           RowBox[{
            RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
            "\[LeftDoubleBracket]", 
            RowBox[{"1", ",", 
             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{"\[Delta]", ",", "2"}], "]"}], "+", "1"}]}], 
            "\[RightDoubleBracket]"}], "]"}], "\[Equal]", 
          RowBox[{"Mprev", "[", 
           RowBox[{
            RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
            "\[LeftDoubleBracket]", 
            RowBox[{"1", ",", 
             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{"\[Delta]", ",", "2"}], "]"}], "+", "1"}]}], 
            "\[RightDoubleBracket]"}], "]"}]}]}], "}"}], ",", 
       "\[IndentingNewLine]", "M", ",", 
       RowBox[{"{", 
        RowBox[{"H", ",", 
         RowBox[{
          RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
          "\[LeftDoubleBracket]", 
          RowBox[{"1", ",", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"\[Delta]", ",", "2"}], "]"}], "+", "1"}]}], 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"decay", "*", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"Mprev", "[", "\"\<Domain\>\"", "]"}], 
                "\[LeftDoubleBracket]", 
                RowBox[{"1", ",", 
                 RowBox[{
                  RowBox[{"Mod", "[", 
                   RowBox[{
                    RowBox[{"\[Delta]", "+", "1"}], ",", "2"}], "]"}], "+", 
                  "1"}]}], "\[RightDoubleBracket]"}], "-", "dH"}], ")"}]}], 
            "+", "dH"}], ")"}], "/.", "params"}]}], "}"}]}], 
      "\[IndentingNewLine]", "]"}], "\[LeftDoubleBracket]", 
     RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.891534495745146*^9, 3.8915345295491085`*^9}, {
   3.8915345804506083`*^9, 3.891534582474359*^9}, {3.891534619083971*^9, 
