  3.891556854684969*^9}},ExpressionUUID->"e84bad9d-f81c-4a50-bda3-\
0ac49b95aae1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"L", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Coth", "[", "x", "]"}], "-", 
   FractionBox["1", "x"]}]}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"c74780ae-8b09-4200-a13f-eb39e4e644cb"],

Cell["Solve for the first curve (ascending in H):", "Text",
 CellChangeTimes->{{3.8915566297650948`*^9, 
  3.89155664383012*^9}},ExpressionUUID->"a6d9be87-d692-4b25-b110-\
eafa8e2789a4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"M0", "[", "params_", "]"}], ":=", 
   RowBox[{"M", "/.", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", " ", 
             RowBox[{"(", " ", 
              RowBox[{
               RowBox[{
                RowBox[{"M", "'"}], "[", "H", "]"}], "/", 
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 RowBox[{"\[Alpha]", " ", 
                  RowBox[{
                   RowBox[{"M", "'"}], "[", "H", "]"}]}]}], ")"}]}], ")"}]}], 
            "\[Equal]", 
            RowBox[{
             RowBox[{"L", "[", 
              FractionBox[
               RowBox[{"H", "+", 
                RowBox[{"\[Alpha]", " ", 
                 RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
             RowBox[{"M", "[", "H", "]"}]}]}], ")"}], "/.", "params"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"M", "[", 
             RowBox[{"Hi0", "+", "dH"}], "]"}], "\[Equal]", "Mi0"}], ")"}], "/.",
           "params"}]}], "}"}], ",", "\[IndentingNewLine]", "M", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"H", ",", 
          RowBox[{"Hi0", "+", "dH"}], ",", 
          RowBox[{"Hf0", "+", "dH"}]}], "}"}], "/.", "params"}]}], "]"}], 
     "\[LeftDoubleBracket]", 
     RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8915313051602387`*^9, 3.8915313207594957`*^9}, {
   3.8915313831831207`*^9, 3.891531440203764*^9}, 3.891531484277697*^9, {
   3.891531617154782*^9, 3.891531645516301*^9}, {3.8915317995790153`*^9, 
   3.891531832234624*^9}, {3.891531877835026*^9, 3.891531887855398*^9}, {
   3.8915321589429293`*^9, 3.8915321739799747`*^9}, 3.8915322369937134`*^9, {
   3.891532442420665*^9, 3.8915324962934666`*^9}, {3.891532579292343*^9, 
   3.8915325941538606`*^9}, {3.89153268262072*^9, 3.891532756320036*^9}, {
   3.891532806313391*^9, 3.8915328140715847`*^9}, {3.8915328647585087`*^9, 
   3.891532938906109*^9}, {3.8915330292295933`*^9, 3.8915330342717295`*^9}, {
   3.89153308708561*^9, 3.8915333017381287`*^9}, {3.891533438380153*^9, 
   3.8915334754943657`*^9}, {3.8915335819571843`*^9, 3.891533593942213*^9}, {
   3.89153363476363*^9, 3.8915336355678844`*^9}, {3.8915336785223475`*^9, 
   3.891533681832311*^9}, {3.8915343041761255`*^9, 3.89153436420822*^9}, 
   3.891534489336593*^9, {3.8915538113239737`*^9, 3.8915538181010838`*^9}, {
