Cell["Repeat the degaussing for N times:", "Text",
 CellChangeTimes->{{3.891556684778736*^9, 
  3.8915566912231083`*^9}},ExpressionUUID->"13f8ccb8-706d-42e0-b259-\
1cf2db895c79"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Hi0", "\[Rule]", 
      RowBox[{"-", ".006"}]}], ",", 
     RowBox[{"Hf0", "\[Rule]", ".006"}], ",", 
     RowBox[{"Mi0", "\[Rule]", 
      RowBox[{"-", ".95"}]}], ",", 
     RowBox[{"a", "\[Rule]", "0.002"}], ",", 
     RowBox[{"\[Alpha]", "\[Rule]", "0.00033"}], ",", 
     RowBox[{"k", "\[Rule]", "0.001"}], ",", 
     RowBox[{"decay", "\[Rule]", "0.8"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dHpar", "[", "dH0_", "]"}], ":=", 
   RowBox[{"params", "~", "Join", "~", 
    RowBox[{"{", 
     RowBox[{"dH", "\[Rule]", "dH0"}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p2", "=", 
   RowBox[{"dHpar", "[", "0", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ntimes", "=", "25"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Marr", " ", "=", " ", 
   RowBox[{"NestList", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Mnext", "[", 
         RowBox[{
          RowBox[{"#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}],
           ",", 
          RowBox[{
           RowBox[{
           "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "+", 
           "1"}], ",", "p2"}], "]"}], ",", 
        RowBox[{
         RowBox[{"#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
         "+", "1"}], ",", "p2"}], "}"}], "&"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M0", "[", "p2", "]"}], ",", "0", ",", "p2"}], "}"}], ",", 
     "Ntimes"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"p", "[", 
     RowBox[{"x", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
     "]"}], ",", 
