    RowBox[{"{", 
     RowBox[{
     "\"\<H [a/\!\(\*SubscriptBox[\(\[Mu]\), \(0\)]\)]\>\"", ",", 
      "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\) [a/\[Mu]0]\>\""}], "}"}]}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{"BaseStyle", "\[Rule]", 
    RowBox[{"FontSize", "\[Rule]", "16"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
