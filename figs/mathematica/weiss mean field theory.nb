    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", "All"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
