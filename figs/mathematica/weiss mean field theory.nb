Cell[CellGroupData[{

Cell["Spiral", "Subsubsection",
 CellChangeTimes->{{3.891531363322461*^9, 
  3.8915313636890154`*^9}},ExpressionUUID->"81063495-b122-4e10-a6d6-\
dfadcd803d1f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hi", "=", 
   RowBox[{"-", "10"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Hf", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mi", "=", 
   RowBox[{"-", ".85"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]", "=", "0.0033"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"k", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"decay", "=", "0.5"}], ";"}]}], "Input",
 CellChangeTimes->{{3.891531368727482*^9, 3.8915313973288183`*^9}, {
