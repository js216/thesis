Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hf", " ", "=", " ", 
   RowBox[{"Hf", " ", "*", " ", "decay"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Mforward", "[", "H_", "]"}], "=", 
   RowBox[{
    RowBox[{"M", "[", "H", "]"}], "/.", 
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"k", " ", 
          RowBox[{
           RowBox[{"M", "'"}], "[", "H", "]"}]}], "\[Equal]", 
         RowBox[{
          RowBox[{"L", "[", 
           FractionBox[
            RowBox[{"H", "+", 
             RowBox[{"\[Alpha]", " ", 
              RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
          RowBox[{"M", "[", "H", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"M", "[", "Hi", "]"}], "\[Equal]", "Mi"}]}], "}"}], ",", 
      "\[IndentingNewLine]", "M", ",", 
      RowBox[{"{", 
       RowBox[{"H", ",", "Hi", ",", "Hf"}], "}"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pf2", "=", 
   RowBox[{"Plot", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"Mforward", "[", "H", "]"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"H", ",", "Hi", ",", "Hf"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Hi", ",", "Hf"}], "}"}], ",", "All"}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotTheme", "\[Rule]", "\"\<Monochrome\>\""}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<H [a/\!\(\*SubscriptBox[\(\[Mu]\), \(0\)]\)]\>\"", ",", 
        "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\) [a/\[Mu]0]\>\""}], "}"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"BaseStyle", "\[Rule]", 
      RowBox[{"FontSize", "\[Rule]", "16"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Hi", "=", 
   RowBox[{"Hi", "*", "decay"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Mbackward", "[", "H_", "]"}], "=", 
   RowBox[{
    RowBox[{"M", "[", "H", "]"}], "/.", 
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", "k"}], " ", 
          RowBox[{
           RowBox[{"M", "'"}], "[", "H", "]"}]}], "\[Equal]", 
         RowBox[{
          RowBox[{"L", "[", 
           FractionBox[
            RowBox[{"H", "+", 
             RowBox[{"\[Alpha]", " ", 
              RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], "-", 
          RowBox[{"M", "[", "H", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"M", "[", "Hf", "]"}], "\[Equal]", 
         RowBox[{"Mforward", "[", "Hf", "]"}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", "M", ",", 
      RowBox[{"{", 
       RowBox[{"H", ",", "Hf", ",", "Hi"}], "}"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pb2", "=", 
   RowBox[{"Plot", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"Mbackward", "[", "H", "]"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"H", ",", "Hi", ",", "Hf"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Hi", ",", "Hf"}], "}"}], ",", "All"}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotTheme", "\[Rule]", "\"\<Monochrome\>\""}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<H [a/\!\(\*SubscriptBox[\(\[Mu]\), \(0\)]\)]\>\"", ",", 
        "\"\<M/\!\(\*SubscriptBox[\(M\), \(s\)]\) [a/\[Mu]0]\>\""}], "}"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"BaseStyle", "\[Rule]", 
      RowBox[{"FontSize", "\[Rule]", "16"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"pf2", ",", "pb2"}], "]"}]}], "Input",
