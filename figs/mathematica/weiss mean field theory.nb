Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MM0", "[", "params_", "]"}], ":=", 
   RowBox[{"M", "/.", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"M", "'"}], "[", "H", "]"}], "\[Equal]", 
            RowBox[{
             RowBox[{
              FractionBox["1", 
               RowBox[{"1", "+", "c"}]], 
              FractionBox[
               RowBox[{
                RowBox[{"Ms", " ", 
                 RowBox[{"L", "[", 
                  FractionBox[
                   RowBox[{"H", "+", 
                    RowBox[{"\[Alpha]", " ", 
                    RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}]}], "-", 
                RowBox[{"M", "[", "H", "]"}]}], 
               RowBox[{"k", "-", 
                RowBox[{"\[Alpha]", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"Ms", " ", 
                    RowBox[{"L", "[", 
                    FractionBox[
                    RowBox[{"H", "+", 
                    RowBox[{"\[Alpha]", " ", 
                    RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}]}], "-", 
                   RowBox[{"M", "[", "H", "]"}]}], ")"}]}]}]]}], "+", 
             RowBox[{
              FractionBox["c", 
               RowBox[{"1", "+", "c"}]], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Ms", " ", 
                 RowBox[{
                  RowBox[{"L", "'"}], "[", 
                  FractionBox[
                   RowBox[{"H", "+", 
                    RowBox[{"\[Alpha]", " ", 
                    RowBox[{"M", "[", "H", "]"}]}]}], "a"], "]"}], 
                 RowBox[{"(", 
                  FractionBox[
                   RowBox[{"1", "+", 
                    RowBox[{"\[Alpha]", " ", 
                    RowBox[{
                    RowBox[{"M", "'"}], "[", "H", "]"}]}]}], "a"], ")"}]}], 
                "-", 
                RowBox[{
                 RowBox[{"M", "'"}], "[", "H", "]"}]}], ")"}]}]}]}], ")"}], "/.",
           "params"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"M", "[", 
             RowBox[{"Hi0", "+", "dH"}], "]"}], "\[Equal]", "Mi0"}], ")"}], "/.",
           "params"}]}], "}"}], ",", "\[IndentingNewLine]", "M", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"H", ",", 
          RowBox[{"Hi0", "+", "dH"}], ",", 
          RowBox[{"Hf0", "+", "dH"}]}], "}"}], "/.", "params"}]}], "]"}], 
     "\[LeftDoubleBracket]", 
     RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}]}], ";"}]], "Input",
