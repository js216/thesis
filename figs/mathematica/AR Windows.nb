Cell[TextData[{
 "Note that our window is now roughly ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "/", "2"}], TraditionalForm]],ExpressionUUID->
  "c17415ed-a418-4d09-be02-88685f5909b9"],
 " thick at 13.3797 GHz (and and integral number of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "/", "2"}], TraditionalForm]],ExpressionUUID->
  "4d0ad134-ca81-4431-908e-c2480b94da53"],
 " at the other three frequencies):"
}], "Text",
 CellChangeTimes->{{3.7294394857396917`*^9, 3.729439539956416*^9}, {
  3.7294395778929887`*^9, 
  3.7294395899091377`*^9}},ExpressionUUID->"62ae8955-e9ba-4f83-8c1b-\
