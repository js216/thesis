Cell[TextData[{
 "The lower bound for reflectivity is realistically set by how precisely the \
window thickness can be controlled. It can be kept below 1% if the window \
thickness can be within about ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", "2"}], "mil"}], TraditionalForm]],ExpressionUUID->
  "56a6567d-489b-400b-b2dc-882ea503d128"],
 ":"
}], "Text",
