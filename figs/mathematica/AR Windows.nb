      SqrtBox["3.8"], ",", 
      RowBox[{
       RowBox[{"d", "/", "1000"}], " ", "m"}], ",", 
      RowBox[{"13.3797", " ", "GHz"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"d", ",", "6"}], "}"}]}], "]"}]}]], "Input",
