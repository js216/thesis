Cell[CellGroupData[{

Cell["Task #2: anti-reflective windows", "Section",
 CellChangeTimes->{{3.7294412434525027`*^9, 3.7294412444604764`*^9}, {
  3.729447762474269*^9, 3.7294477655840225`*^9}, {3.729448108665417*^9, 
  3.7294481128570967`*^9}},ExpressionUUID->"685a032e-fd50-4e13-92de-\
6fcb85031b12"],

Cell[TextData[{
 "See ",
 StyleBox["Thin-Film Optical Filters",
  FontSlant->"Italic"],
 " by H A Macleod for thin-film theory; I merely quote results in what \
follows."
}], "Text",
 CellChangeTimes->{{3.729441109357561*^9, 3.7294411160178747`*^9}, {
  3.7294416030268087`*^9, 
  3.729441603473571*^9}},ExpressionUUID->"37271751-9285-4aea-9dfe-\
3a072e28b8c5"],

Cell[CellGroupData[{

Cell["Thin film reflectance at normal incidence", "Subsubsection",
 CellChangeTimes->{{3.729424084001368*^9, 3.729424092889123*^9}, {
  3.72942506303209*^9, 3.729425064216807*^9}, {3.7294337966046495`*^9, 
  3.7294338039332094`*^9}, {3.729436517882084*^9, 
  3.729436530696679*^9}},ExpressionUUID->"68c833ef-2579-4859-a5a6-\
92317391d01a"],

Cell["The wavelength in vacuum is", "Text",
 CellChangeTimes->{{3.72942459076408*^9, 3.729424602056255*^9}, 
   3.895170173957829*^9, {3.8951702905379343`*^9, 
   3.895170291168129*^9}},ExpressionUUID->"0171a396-03cd-4e9e-8af1-\
044e4c51ee69"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Lambda]", "[", 
   RowBox[{"n_", ",", "f_"}], "]"}], ":=", 
  FractionBox["c", 
   RowBox[{" ", "f"}]]}]], "Input",
 CellChangeTimes->{{3.729424651228256*^9, 3.729424691737897*^9}, 
   3.895170293674078*^9},
 CellLabel->
  "In[335]:=",ExpressionUUID->"f8555ed2-9aa7-48fb-84c6-b0d2b7cd8ec6"],

Cell[TextData[{
 "The phase change for planar wavefronts at normal incidence across a window \
of thickness ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "737e0d71-a6c7-46af-a586-83bf2f475bbd"],
 " and refractive index ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cf176d5c-4e69-48e6-bbb7-81d279e3dff5"],
 " will be"
}], "Text",
 CellChangeTimes->{{3.7294372411191463`*^9, 3.7294372793840103`*^9}, {
  3.729437338440154*^9, 3.7294373717517767`*^9}, {3.7294374593677335`*^9, 
  3.729437459847821*^9}, {3.729437518230954*^9, 3.7294375183596334`*^9}, {
  3.729441106419*^9, 3.729441107363416*^9}, {3.7294473962690353`*^9, 
  3.7294474017547655`*^9}},ExpressionUUID->"f2488c37-b4ec-42c3-9a8a-\
f348aee67490"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Delta]", "[", 
   RowBox[{"n_", ",", "d_", ",", "f_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{"2", "\[Pi]", " ", "n", " ", "d"}], 
   RowBox[{"\[Lambda]", "[", 
    RowBox[{"n", ",", "f"}], "]"}]]}]], "Input",
 CellChangeTimes->{{3.729437280634762*^9, 3.7294373036418953`*^9}, {
  3.729438327787654*^9, 3.7294383443914037`*^9}},
 CellLabel->
  "In[336]:=",ExpressionUUID->"7dd12e1c-4254-4e52-985a-99e4624af30f"],

Cell["The admittance of the window is given by [see eqn 2.92]", "Text",
 CellChangeTimes->{{3.7294374630772285`*^9, 
  3.7294374831433816`*^9}},ExpressionUUID->"97b548d0-93e8-4297-9882-\
b2c41226526d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Y", "[", 
   RowBox[{"n_", ",", "d_", ",", "f_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{
    RowBox[{"y0", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"\[Delta]", "[", 
       RowBox[{"n", ",", "d", ",", "f"}], "]"}], "]"}]}], "+", 
    RowBox[{"\[ImaginaryI]", " ", "y1", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Delta]", "[", 
       RowBox[{"n", ",", "d", ",", "f"}], "]"}], "]"}]}]}], 
   RowBox[{
    RowBox[{"Cos", "[", 
     RowBox[{"\[Delta]", "[", 
      RowBox[{"n", ",", "d", ",", "f"}], "]"}], "]"}], "+", 
    RowBox[{"\[ImaginaryI]", 
     RowBox[{"(", 
      RowBox[{"y0", "/", "y1"}], ")"}], 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Delta]", "[", 
       RowBox[{"n", ",", "d", ",", "f"}], "]"}], "]"}]}]}]]}]], "Input",
 CellChangeTimes->{{3.729437471499506*^9, 3.7294375579796925`*^9}, {
  3.7294384055812316`*^9, 3.7294384275754895`*^9}},
 CellLabel->
  "In[337]:=",ExpressionUUID->"0bc934f5-4ed4-4e2d-b6cd-2f18424d24db"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "0"], TraditionalForm]],ExpressionUUID->
  "893b8d14-5724-4b77-b71a-c91e3093da3c"],
 " is the admittance of free space, while for an ideal dielectric window, its \
admittance will be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], "=", 
    SqrtBox[
     RowBox[{
      SubscriptBox["\[Epsilon]", "1"], "/", 
      SubscriptBox["\[Mu]", "1"]}]]}], TraditionalForm]],ExpressionUUID->
  "eda99bc6-b612-4459-be87-9830b00cb66f"],
 ". Since for dielectrics, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[TildeTilde]", 
    SubscriptBox["\[Mu]", "0"]}], TraditionalForm]],ExpressionUUID->
  "14ffd068-64a4-4298-9c38-44d2b9b50070"],
 ", we can assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], "\[TildeTilde]", 
    RowBox[{
     SqrtBox[
      SubscriptBox["\[Epsilon]", "r"]], 
     SubscriptBox["y", "0"]}]}], TraditionalForm]],ExpressionUUID->
  "2575f10c-15f4-4c1d-9422-03fda231acf9"],
 ". For fused silica, respectively, these values are approximately"
}], "Text",
 CellChangeTimes->{{3.7294375591478076`*^9, 3.729437608071656*^9}, {
  3.729437643319352*^9, 3.729437724247712*^9}, {3.7294377845191035`*^9, 
  3.729437788038702*^9}, {3.7294381808552427`*^9, 3.729438224422681*^9}, {
  3.7294382985190725`*^9, 3.7294383111421027`*^9}, {3.7294476393538218`*^9, 
  3.7294476504606285`*^9}},ExpressionUUID->"8817cfd8-a233-4d15-8bd9-\
9225e6c38bb7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"y1", "=", 
   RowBox[{
    SqrtBox["3.8"], "y0"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7294377898990164`*^9, 3.729437852487893*^9}, {
  3.729437942953643*^9, 3.7294379877041864`*^9}, {3.7294380295465913`*^9, 
  3.729438056236726*^9}, {3.7294382412415895`*^9, 3.7294382860384336`*^9}, {
  3.7294403908235817`*^9, 3.7294403946764216`*^9}, {3.7294476591948376`*^9, 
  3.729447660297268*^9}},
 CellLabel->
  "In[338]:=",ExpressionUUID->"55911f4d-2687-4ca1-b44a-6aa12e623c5d"],

Cell["The corresponding power reflectivity is [eqn 2.91]", "Text",
 CellChangeTimes->{{3.7294384682853017`*^9, 
  3.7294384783258095`*^9}},ExpressionUUID->"bd206927-bbdc-4d84-80e6-\
c9b46bf07ea8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"R", "[", 
   RowBox[{"n_", ",", "d_", ",", "f_"}], "]"}], ":=", 
  SuperscriptBox[
   RowBox[{"Abs", "[", 
    FractionBox[
     RowBox[{"y0", "-", 
      RowBox[{"Y", "[", 
       RowBox[{"n", ",", "d", ",", "f"}], "]"}]}], 
     RowBox[{"y0", "+", 
      RowBox[{"Y", "[", 
       RowBox[{"n", ",", "d", ",", "f"}], "]"}]}]], "]"}], "2"]}]], "Input",
 CellChangeTimes->{{3.72943848226523*^9, 3.7294385315774994`*^9}},
 CellLabel->
  "In[339]:=",ExpressionUUID->"9645cb08-55e4-4bdc-9c31-5d61be7f6d6b"],

