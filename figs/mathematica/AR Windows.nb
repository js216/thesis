      RowBox[{
       RowBox[{"d", "/", "1000"}], " ", "m"}], ",", 
      RowBox[{"13.3797", " ", "GHz"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"d", ",", "6"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.7294388632450314`*^9, 3.7294388826807466`*^9}, {
