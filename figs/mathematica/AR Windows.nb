Cell[CellGroupData[{

Cell["Estimate the angle of incidence", "Subsubsection",
 CellChangeTimes->{{3.729957854439212*^9, 
  3.729957862743209*^9}},ExpressionUUID->"11d4ab8a-fdb6-41b9-af4b-\
2dd1526b54e3"],

Cell["The radius of curvature, beam waist, and intensity are", "Text",
 CellChangeTimes->{{3.7299578743793955`*^9, 3.729957877270746*^9}, {
  3.895229304541238*^9, 3.895229307593149*^9}, {3.89522973552715*^9, 
  3.895229748059641*^9}},ExpressionUUID->"fd30c175-480d-4d7e-a196-\
c63a82fdb068"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"R", "[", 
   RowBox[{"z_", ",", "w0_", ",", "f_"}], "]"}], ":=", 
  RowBox[{"z", "+", 
   RowBox[{
    FractionBox["1", "z"], 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox[
       RowBox[{"\[Pi]", " ", 
        SuperscriptBox["w0", "2"]}], 
       RowBox[{"c", "/", "f"}]], ")"}], "2"]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"w", "[", 
   RowBox[{"z_", ",", "w0_", ",", "f_"}], "]"}], ":=", 
  RowBox[{"w0", 
   SqrtBox[
    RowBox[{"1", "+", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{"c", "/", "f"}], ")"}], " ", "z"}], 
        RowBox[{"\[Pi]", " ", 
         SuperscriptBox["w0", "2"]}]], ")"}], 
      "2"]}]]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"I0", "[", 
   RowBox[{"r_", ",", "z_", ",", "w0_", ",", "f_"}], "]"}], ":=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox["w0", 
      RowBox[{"w", "[", 
       RowBox[{"z", ",", "w0", ",", "f"}], "]"}]], ")"}], "2"], 
   RowBox[{"Exp", "[", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"2", 
       SuperscriptBox["r", "2"]}], 
      SuperscriptBox[
       RowBox[{"w", "[", 
        RowBox[{"z", ",", "w0", ",", "f"}], "]"}], "2"]]}], 
    "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.729957878300024*^9, 3.7299579036369467`*^9}, 
   3.7299579427921247`*^9, {3.729964242159649*^9, 3.7299642422564073`*^9}, {
   3.895227913874411*^9, 3.895227920272423*^9}, {3.89522931109262*^9, 
   3.895229312673785*^9}, {3.89522934329401*^9, 3.895229365854357*^9}, {
