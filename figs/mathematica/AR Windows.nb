Cell[CellGroupData[{

Cell["The effect of oblique incidence", "Subsubsection",
 CellChangeTimes->{{3.729959594731311*^9, 
  3.729959602216818*^9}},ExpressionUUID->"d01c1102-0a13-44a0-be5b-\
dc556effb664"],

Cell[TextData[{
 "The phase change for planar wavefronts at normal incidence across a window \
of thickness ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "cb69e0b5-8034-4d6b-b0f4-6289f0f6f85e"],
 " and refractive index ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "160a48b1-0692-42c7-8d5b-198653cfde72"],
 " will be"
}], "Text",
 CellChangeTimes->{{3.7294372411191463`*^9, 3.7294372793840103`*^9}, {
  3.729437338440154*^9, 3.7294373717517767`*^9}, {3.7294374593677335`*^9, 
  3.729437459847821*^9}, {3.729437518230954*^9, 3.7294375183596334`*^9}, {
  3.729441106419*^9, 3.729441107363416*^9}, {3.7294473962690353`*^9, 
  3.7294474017547655`*^9}},ExpressionUUID->"11f42803-47c1-4e7f-bbf4-\
93160d14762d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Delta]2", "[", 
   RowBox[{"n_", ",", "d_", ",", "f_", ",", "\[Theta]_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{"2", "\[Pi]", " ", "n", " ", "d", " ", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}]}], 
   RowBox[{"\[Lambda]", "[", 
    RowBox[{"n", ",", "f"}], "]"}]]}]], "Input",
 CellChangeTimes->{{3.729437280634762*^9, 3.7294373036418953`*^9}, {
   3.729438327787654*^9, 3.7294383443914037`*^9}, {3.7299573723294497`*^9, 
   3.729957380616681*^9}, {3.7299576903290944`*^9, 3.729957690489383*^9}, {
   3.7299642320968*^9, 3.7299642331349964`*^9}, 3.895225212141458*^9},
 CellLabel->
  "In[358]:=",ExpressionUUID->"94f96ab6-ab43-41bb-a043-87a5883b1306"],

Cell["The admittance of the window is given by [see eqn 2.92]", "Text",
 CellChangeTimes->{{3.7294374630772285`*^9, 
  3.7294374831433816`*^9}},ExpressionUUID->"16dc4497-3de4-44a9-b6e0-\
e0feca92b121"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Y2", "[", 
   RowBox[{"n_", ",", "d_", ",", "f_", ",", "\[Theta]_"}], "]"}], ":=", 
  RowBox[{"y0", 
   FractionBox[
    RowBox[{" ", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"\[Delta]2", "[", 
        RowBox[{"n", ",", "d", ",", "f", ",", "\[Theta]"}], "]"}], "]"}], "+", 
      RowBox[{"\[ImaginaryI]", " ", "n", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Delta]2", "[", 
         RowBox[{"n", ",", "d", ",", "f", ",", "\[Theta]"}], "]"}], 
        "]"}]}]}]}], 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Delta]2", "[", 
       RowBox[{"n", ",", "d", ",", "f", ",", "\[Theta]"}], "]"}], "]"}], "+", 
     RowBox[{"\[ImaginaryI]", 
      RowBox[{"(", 
       RowBox[{"1", "/", "n"}], ")"}], 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Delta]2", "[", 
        RowBox[{"n", ",", "d", ",", "f", ",", "\[Theta]"}], "]"}], 
       "]"}]}]}]]}]}]], "Input",
 CellChangeTimes->{{3.729437471499506*^9, 3.7294375579796925`*^9}, {
  3.7294384055812316`*^9, 3.7294384275754895`*^9}, {3.7299573952260437`*^9, 
  3.729957407592792*^9}, {3.7299575585536923`*^9, 3.7299575950487947`*^9}, {
  3.8952252034400797`*^9, 3.8952252180663958`*^9}},
 CellLabel->
  "In[359]:=",ExpressionUUID->"b9337005-89b9-4047-8955-21acc4e81bd8"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "0"], TraditionalForm]],ExpressionUUID->
  "e45f8dd4-0a9d-4a75-b68e-775406d408a5"],
 " is the admittance of free space, while for an ideal dielectric window, its \
admittance will be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], "=", 
    SqrtBox[
     RowBox[{
      SubscriptBox["\[Epsilon]", "1"], "/", 
      SubscriptBox["\[Mu]", "1"]}]]}], TraditionalForm]],ExpressionUUID->
  "4a31c739-e8f5-412b-8f8f-f07110aa4337"],
 ". Since for dielectrics, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[TildeTilde]", 
    SubscriptBox["\[Mu]", "0"]}], TraditionalForm]],ExpressionUUID->
  "b96390c7-0754-437a-ad17-feb56c204948"],
 ", we can assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], "\[TildeTilde]", 
    RowBox[{
     SqrtBox[
      SubscriptBox["\[Epsilon]", "r"]], 
     SubscriptBox["y", "0"]}]}], TraditionalForm]],ExpressionUUID->
  "de251df0-6a88-4d2a-8173-47a7a05a71d3"],
 ". For fused silica, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Epsilon]", "r"], "\[TildeTilde]", "3.8"}], 
   TraditionalForm]],ExpressionUUID->"08d319ea-0e4e-4d46-a1b6-a07fe775586f"],
 "."
}], "Text",
 CellChangeTimes->{{3.7294375591478076`*^9, 3.729437608071656*^9}, {
  3.729437643319352*^9, 3.729437724247712*^9}, {3.7294377845191035`*^9, 
  3.729437788038702*^9}, {3.7294381808552427`*^9, 3.729438224422681*^9}, {
  3.7294382985190725`*^9, 3.7294383111421027`*^9}, {3.7294476393538218`*^9, 
  3.7294476504606285`*^9}, {3.7299574501369286`*^9, 3.729957466343915*^9}, {
  3.7299575771607924`*^9, 
  3.7299575800406632`*^9}},ExpressionUUID->"d0127bd6-b808-4ee9-a039-\
17399ae43318"],

Cell["The corresponding power reflectivity is [eqn 2.91]", "Text",
 CellChangeTimes->{{3.7294384682853017`*^9, 
  3.7294384783258095`*^9}},ExpressionUUID->"1b9b4a8c-3d55-48b0-b6cb-\
c0bd7a27ca36"],

Cell[BoxData[
 RowBox[{
  RowBox[{"R2", "[", 
   RowBox[{"n_", ",", "d_", ",", "f_", ",", "\[Theta]_"}], "]"}], ":=", 
  SuperscriptBox[
   RowBox[{"Abs", "[", 
    FractionBox[
     RowBox[{"y0", "-", 
      RowBox[{"Y2", "[", 
       RowBox[{"n", ",", "d", ",", "f", ",", "\[Theta]"}], "]"}]}], 
     RowBox[{"y0", "+", 
      RowBox[{"Y2", "[", 
       RowBox[{"n", ",", "d", ",", "f", ",", "\[Theta]"}], "]"}]}]], "]"}], 
   "2"]}]], "Input",
 CellChangeTimes->{{3.72943848226523*^9, 3.7294385315774994`*^9}, {
  3.729957489673709*^9, 3.7299574995136833`*^9}, {3.895225204780712*^9, 
  3.895225207374552*^9}},
 CellLabel->
  "In[360]:=",ExpressionUUID->"40aeae06-1a99-48b1-ba0f-15b3ef5a1683"],

