  3.7468157979503803`*^9, 3.7468158211203136`*^9}, {3.746816048947697*^9, 
  3.7468160513074665`*^9}, {3.7468694106040416`*^9, 3.746869422376813*^9}, {
  3.7468695090054665`*^9, 3.7468695110052776`*^9}, {3.7468704489777255`*^9, 
