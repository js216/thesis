  RowBox[{
   RowBox[{"Fc", "[", 
    RowBox[{"d_", ",", "\[Lambda]_"}], "]"}], ":=", 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"m", "=", "1"}], "mMAX"], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["m", "2"], "-", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"d", "/", "\[Lambda]"}], ")"}], "2"]}], ")"}], 
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}]], "-", 
      FractionBox["1", "m"]}], ")"}]}]}], ";"}]}], "Input",
