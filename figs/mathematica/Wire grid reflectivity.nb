 CellLabel->"In[86]:=",ExpressionUUID->"98b0c2f2-8317-4215-b20b-9a7388bda1fc"],

Cell["The reflection coefficient is", "Text",
 CellChangeTimes->{{3.7468146485285654`*^9, 
  3.7468146542914896`*^9}},ExpressionUUID->"92b5147d-29ae-4338-a6b3-\
bb229de8b3d8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", 
    RowBox[{"a_", ",", "d_", ",", "\[Lambda]_"}], "]"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], 
     RowBox[{"1", "+", 
      RowBox[{"2", 
       RowBox[{
        RowBox[{"Zg", "[", 
         RowBox[{"a", ",", "d", ",", "\[Lambda]"}], "]"}], "/", "Z0"}]}]}]], "//",
     "FullSimplify"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7468146575800705`*^9, 3.746814669699467*^9}, {
   3.746815872280396*^9, 3.7468158736543307`*^9}, {3.746815946136365*^9, 
   3.746815949866499*^9}, {3.7468160565774097`*^9, 3.746816059287759*^9}, {
   3.7468694311041107`*^9, 3.746869434024086*^9}, 3.746869513154748*^9, {
