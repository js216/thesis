Cell[BoxData[
 RowBox[{
  RowBox[{"T", "[", 
   RowBox[{"a_", ",", "d_", ",", "\[Lambda]_"}], "]"}], ":=", 
  RowBox[{"1", "-", 
   SuperscriptBox[
    RowBox[{"Abs", "[", 
     RowBox[{"R", "[", 
      RowBox[{"a", ",", "d", ",", "\[Lambda]"}], "]"}], "]"}], 
