       RowBox[{"-", "6"}]], "\[CapitalOmega]", " ", "cm"}]]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"conductivity", " ", "of", " ", "wires"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
