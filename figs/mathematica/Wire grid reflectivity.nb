Cell[BoxData[{
 RowBox[{"$Assumptions", ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"Im", "[", "\[CapitalOmega]", "]"}], "\[Equal]", "0"}], ",", 
