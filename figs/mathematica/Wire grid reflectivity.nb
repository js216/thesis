 CellLabel->"In[96]:=",ExpressionUUID->"0e2f4ce7-4c8e-473f-9ce2-106b7540316e"],

Cell["\<\
The equivalent shunt impedance of the grid is given by [eqn 25]:\
\>", "Text",
 CellChangeTimes->{{3.7468134180171413`*^9, 3.746813427567384*^9}, {
  3.746869503114399*^9, 3.7468695065155697`*^9}, {3.895237998861065*^9, 
  3.8952380000134163`*^9}},ExpressionUUID->"419676f2-1c22-4ce9-8b02-\
d49d3ac83e26"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Zg", "[", 
    RowBox[{"a_", ",", "d_", ",", "\[Lambda]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"\[ImaginaryI]", " ", "Z0", 
     FractionBox["d", "\[Lambda]"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Log", "[", 
        FractionBox["d", 
         RowBox[{"2", "\[Pi]", " ", "a"}]], "]"}], "+", 
       RowBox[{"Fc", "[", 
        RowBox[{"d", ",", "\[Lambda]"}], "]"}]}], ")"}]}], "+", 
    RowBox[{"d", " ", 
     RowBox[{"Zi", "[", 
      RowBox[{"a", ",", "\[Lambda]"}], "]"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.746813430036995*^9, 3.7468134326372013`*^9}, {
  3.7468134930672674`*^9, 3.746813552678376*^9}, {3.7468142444360247`*^9, 
  3.746814320216032*^9}, {3.7468144074409156`*^9, 3.7468144099581003`*^9}, {
  3.7468155354681168`*^9, 3.7468155361878586`*^9}, {3.7468156185682507`*^9, 
