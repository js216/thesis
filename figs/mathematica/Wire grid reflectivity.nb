494ff832565f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Zi", "[", 
   RowBox[{"a_", ",", "\[Lambda]_"}], "]"}], ":=", 
  RowBox[{
   SqrtBox[
    FractionBox[
     RowBox[{"\[Mu]1", " ", "2", "\[Pi]", " ", "c"}], 
     RowBox[{"2", "\[Sigma]", " ", "\[Lambda]"}]]], 
   FractionBox[
    RowBox[{"1", "+", "\[ImaginaryI]"}], 
    RowBox[{"2", "\[Pi]", " ", "a"}]]}]}]], "Input",
 CellChangeTimes->{{3.7468137809007635`*^9, 3.7468138717203608`*^9}, {
   3.746813995901719*^9, 3.746813997211722*^9}, {3.7468140868668413`*^9, 
