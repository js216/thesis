  RowBox[{"\[Epsilon]0", "=", 
   RowBox[{"8.85", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "12"}]], 
    RowBox[{
     FractionBox["s", "\[CapitalOmega]"], "/", "m"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
