\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces AC level stabilization against non-adiabatic transitions when subjected to time-varying electric fields. $\epsilon ^\text  {\textsc  {dc}}_\text  {i}=-\epsilon ^\text  {\textsc  {dc}}_\text  {f}=20$, $\alpha =0.01$, $\beta =0.1$, $\delta =1$. \textit  {\textbf  {a.}} The transition-probability interference fringes as a function of field reversal time, with the time dependence of the field and the eigenenergies illustrated in the left plots. $T_0=8$, $\Delta T=2$. \textit  {\textbf  {b.}} Adding an \textsc  {ac}\ field results (magnitude shown in left plot, dashed line) in separated regions of high $P_\text  {trans}$ against a transition-free background (right plot). $T_0=1$, $T_\text  {fall}^\text  {\,\textsc  {dc}}=196.6$, $\Delta T=200$, $T_\text  {rise}^\text  {\,\textsc  {ac}}=T_\text  {fall}^\text  {\,\textsc  {ac}}=1$.\relax }}{56}{figure.caption.41}\protected@file@percent }
\newlabel{floquet}{{11}{56}{AC level stabilization against non-adiabatic transitions when subjected to time-varying electric fields. $\epsilon ^\text {\DC }_\text {i}=-\epsilon ^\text {\DC }_\text {f}=20$, $\alpha =0.01$, $\beta =0.1$, $\delta =1$. \part {a} The transition-probability interference fringes as a function of field reversal time, with the time dependence of the field and the eigenenergies illustrated in the left plots. $T_0=8$, $\Delta T=2$. \part {b} Adding an \AC \ field results (magnitude shown in left plot, dashed line) in separated regions of high $P_\text {trans}$ against a transition-free background (right plot). $T_0=1$, $T_\text {fall}^\text {\,\DC }=196.6$, $\Delta T=200$, $T_\text {rise}^\text {\,\AC }=T_\text {fall}^\text {\,\AC }=1$.\relax }{figure.caption.41}{}}
