\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Eigenstates of the $6\times 6$ Hamiltonian $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle H$}\mathaccent "0365{H}_{nm}^{jk}$, where $n,m$ are the indices of the original $2\times 2$ atomic Hamiltonian, and $j,k$ here limited to the $\{-1,0,1\}$ part of the infinite Hilbert space. Without the \textsc  {ac}\ field, note that the spectrum resembles that of the atomic Hamiltonian (as in Fig.~\ref {floquet}), thrice replicated. As the \textsc  {ac}\ is turned stronger, the location of the avoided crossings moves around or disappears.\relax }}{60}{figure.caption.42}\protected@file@percent }
\newlabel{dressed}{{12}{60}{Eigenstates of the $6\times 6$ Hamiltonian $\widetilde {H}_{nm}^{jk}$, where $n,m$ are the indices of the original $2\times 2$ atomic Hamiltonian, and $j,k$ here limited to the $\{-1,0,1\}$ part of the infinite Hilbert space. Without the \AC \ field, note that the spectrum resembles that of the atomic Hamiltonian (as in Fig.~\ref {floquet}), thrice replicated. As the \AC \ is turned stronger, the location of the avoided crossings moves around or disappears.\relax }{figure.caption.42}{}}
