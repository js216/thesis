Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    RowBox[{"\[CapitalDelta]B", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["a", "3"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}]}], "-", 
       RowBox[{"2", " ", 
        SuperscriptBox["b", "3"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}]}]}], ")"}]}], 
    RowBox[{
     RowBox[{"2", " ", 
      SuperscriptBox["a", "3"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}], "2"]}], "-", 
     RowBox[{
      SuperscriptBox["b", "3"], " ", 
      RowBox[{"(", 
       RowBox[{"2", "+", "\[Mu]"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"2", " ", "\[Mu]"}]}], ")"}]}]}]], "+", 
   FractionBox[
    RowBox[{"9", " ", 
     SuperscriptBox["b", "3"], " ", "H0", " ", "\[Mu]"}], 
    RowBox[{
     RowBox[{"2", " ", 
      SuperscriptBox["a", "3"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}], "2"]}], "-", 
     RowBox[{
      SuperscriptBox["b", "3"], " ", 
      RowBox[{"(", 
       RowBox[{"2", "+", "\[Mu]"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"2", " ", "\[Mu]"}]}], ")"}]}]}]]}], "}"}]], "Output",
 CellChangeTimes->{{3.8913706635698395`*^9, 3.8913706794396687`*^9}},
 CellLabel->
