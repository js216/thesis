Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Hin", "=", 
  RowBox[{
   RowBox[{"Grad", "[", 
    RowBox[{
     RowBox[{"\[CapitalPhi]in", "[", 
      RowBox[{"r", ",", "\[Theta]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "}"}], ",", 
     "\"\<Spherical\>\""}], "]"}], "//", "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.8913637761584573`*^9, 3.891363816261325*^9}, 
   3.8913638483953667`*^9, {3.8913640355344505`*^9, 3.891364062347068*^9}, {
