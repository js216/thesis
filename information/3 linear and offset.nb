c7f41aed0cfc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"eqns", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Alpha]1", "-", 
       RowBox[{
        SuperscriptBox["b", "3"], "\[Beta]1"}], "-", "\[Gamma]1"}], 
      "\[Equal]", 
      RowBox[{
       SuperscriptBox["b", "3"], "H0"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"2", "\[Alpha]1"}], "+", 
       RowBox[{"\[Mu]", " ", 
        SuperscriptBox["b", "3"], "\[Beta]1"}], "-", 
       RowBox[{"2", "\[Mu]", " ", "\[Gamma]1"}]}], "\[Equal]", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["b", "3"]}], "H0"}], "+", 
       RowBox[{
        SuperscriptBox["b", "3"], "\[CapitalDelta]B"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["a", "3"], "\[Beta]1"}], "+", "\[Gamma]1", "-", 
       RowBox[{
        SuperscriptBox["a", "3"], "\[Delta]1"}]}], "\[Equal]", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Mu]", " ", 
        SuperscriptBox["a", "3"], "\[Beta]1"}], "-", 
       RowBox[{"2", "\[Mu]", " ", "\[Gamma]1"}], "-", 
       RowBox[{
        SuperscriptBox["a", "3"], "\[Delta]1"}], "+", 
       RowBox[{
        SuperscriptBox["a", "3"], "\[CapitalDelta]B"}]}], "\[Equal]", "0"}]}],
     "\[IndentingNewLine]", "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.891340571272275*^9, 3.8913406698408146`*^9}, {
   3.8913407009924154`*^9, 3.8913407193812504`*^9}, {3.8913694048466916`*^9, 
