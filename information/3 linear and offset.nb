Notebook[{

Cell[CellGroupData[{
Cell["Magnetic scalar potential", "Subsubsection",
 CellChangeTimes->{{3.891363670316662*^9, 
  3.891363672307562*^9}},ExpressionUUID->"536b9f29-321c-48f8-bd0c-\
376aea207365"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{
     RowBox[{"\[Mu]", " ", "H"}], "+", 
     RowBox[{"\[CapitalDelta]", " ", "B"}]}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "cbe4f030-d9bb-4272-8a22-3c0a0c5d1584"],
 " inside the material (paramagnetic + offset).\n\nAdapting Jackson eqn \
5.120, we have to solve the system:"
}], "Text",
 CellChangeTimes->{{3.8913404810092463`*^9, 3.8913405084779434`*^9}, {
  3.891369092511777*^9, 3.8913691278398447`*^9}, {3.891369308752914*^9, 
  3.8913693111159897`*^9}},ExpressionUUID->"b7db0202-7981-4cd0-94dd-\
c7f41aed0cfc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"eqns", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Alpha]1", "-", 
       RowBox[{
        SuperscriptBox["b", "3"], "\[Beta]1"}], "-", "\[Gamma]1"}], 
      "\[Equal]", 
      RowBox[{
       SuperscriptBox["b", "3"], "H0"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"2", "\[Alpha]1"}], "+", 
       RowBox[{"\[Mu]", " ", 
        SuperscriptBox["b", "3"], "\[Beta]1"}], "-", 
       RowBox[{"2", "\[Mu]", " ", "\[Gamma]1"}]}], "\[Equal]", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["b", "3"]}], "H0"}], "+", 
       RowBox[{
        SuperscriptBox["b", "3"], "\[CapitalDelta]B"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["a", "3"], "\[Beta]1"}], "+", "\[Gamma]1", "-", 
       RowBox[{
        SuperscriptBox["a", "3"], "\[Delta]1"}]}], "\[Equal]", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Mu]", " ", 
        SuperscriptBox["a", "3"], "\[Beta]1"}], "-", 
       RowBox[{"2", "\[Mu]", " ", "\[Gamma]1"}], "-", 
       RowBox[{
        SuperscriptBox["a", "3"], "\[Delta]1"}], "-", 
       RowBox[{
        SuperscriptBox["a", "3"], "\[CapitalDelta]B"}]}], "\[Equal]", "0"}]}],
     "\[IndentingNewLine]", "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.891340571272275*^9, 3.8913406698408146`*^9}, {
  3.8913407009924154`*^9, 3.8913407193812504`*^9}, {3.8913694048466916`*^9, 
  3.8913694058025665`*^9}, {3.891369492590195*^9, 3.8913694933074627`*^9}, {
  3.891369550439701*^9, 3.891369556854496*^9}},
 CellLabel->
  "4/24/23 19:00:30 \
In[271]:=",ExpressionUUID->"4fb065b2-1b5b-4bfa-909c-6f6cf425f94a"],

Cell["The solution is:", "Text",
 CellChangeTimes->{{3.8913406714688034`*^9, 
  3.8913406743419104`*^9}},ExpressionUUID->"4ce15d60-275d-4b8a-81e2-\
4f371086a2ce"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"soln", "=", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{"eqns", ",", 
     RowBox[{"{", 
      RowBox[{
      "\[Alpha]1", ",", "\[Beta]1", ",", "\[Gamma]1", ",", "\[Delta]1"}], 
      "}"}]}], "]"}], "//", "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.891340571272275*^9, 3.8913406885702925`*^9}, {
  3.891340735695532*^9, 3.8913407364995356`*^9}, {3.8913457015639973`*^9, 
  3.8913457020662003`*^9}},
 CellLabel->
  "4/24/23 19:00:31 \
In[272]:=",ExpressionUUID->"bb8ab3fd-0b0c-4024-b1d1-da5749ed8458"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Alpha]1", "\[Rule]", 
     FractionBox[
      RowBox[{
       SuperscriptBox["b", "3"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["a", "3"]}], "+", 
         SuperscriptBox["b", "3"]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"\[CapitalDelta]B", "+", 
         RowBox[{"H0", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}]}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"2", " ", "\[Mu]"}]}], ")"}]}], 
      RowBox[{
       RowBox[{
        RowBox[{"-", "2"}], " ", 
        SuperscriptBox["a", "3"], " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}], "2"]}], "+", 
       RowBox[{
        SuperscriptBox["b", "3"], " ", 
        RowBox[{"(", 
         RowBox[{"2", "+", "\[Mu]"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"2", " ", "\[Mu]"}]}], ")"}]}]}]]}], ",", 
    RowBox[{"\[Beta]1", "\[Rule]", 
     FractionBox[
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["a", "3"], " ", "\[CapitalDelta]B", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}]}], "+", 
       RowBox[{
        SuperscriptBox["b", "3"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"3", " ", "H0"}], "-", "\[CapitalDelta]B"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"2", " ", "\[Mu]"}]}], ")"}]}]}], 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["a", "3"], " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}], "2"]}], "-", 
       RowBox[{
        SuperscriptBox["b", "3"], " ", 
        RowBox[{"(", 
         RowBox[{"2", "+", "\[Mu]"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"2", " ", "\[Mu]"}]}], ")"}]}]}]]}], ",", 
    RowBox[{"\[Gamma]1", "\[Rule]", 
     FractionBox[
      RowBox[{"3", " ", 
       SuperscriptBox["a", "3"], " ", 
       SuperscriptBox["b", "3"], " ", 
       RowBox[{"(", 
        RowBox[{"\[CapitalDelta]B", "+", 
         RowBox[{"H0", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}]}]}], ")"}]}], 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["a", "3"], " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}], "2"]}], "-", 
       RowBox[{
        SuperscriptBox["b", "3"], " ", 
        RowBox[{"(", 
         RowBox[{"2", "+", "\[Mu]"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"2", " ", "\[Mu]"}]}], ")"}]}]}]]}], ",", 
    RowBox[{"\[Delta]1", "\[Rule]", 
     FractionBox[
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["a", "3"], " ", "\[CapitalDelta]B", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}]}], "+", 
       RowBox[{
        SuperscriptBox["b", "3"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "2"}], " ", "\[CapitalDelta]B", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}]}], "+", 
          RowBox[{"9", " ", "H0", " ", "\[Mu]"}]}], ")"}]}]}], 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["a", "3"], " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Mu]"}], ")"}], "2"]}], "-", 
       RowBox[{
        SuperscriptBox["b", "3"], " ", 
        RowBox[{"(", 
         RowBox[{"2", "+", "\[Mu]"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"2", " ", "\[Mu]"}]}], ")"}]}]}]]}]}], "}"}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.8913696243262777`*^9, 3.8913696319121404`*^9}},
 CellLabel->
  "4/24/23 19:00:31 \
Out[272]=",ExpressionUUID->"af8f09e9-8415-4e77-affd-afe6df17e330"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Collect", "[", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"\[Delta]1", "/.", "soln"}], ")"}], ",", "\[CapitalDelta]B"}], 
  "]"}]], "Input",
