Cell[CellGroupData[{

Cell["Field", "Subsubsection",
 CellChangeTimes->{{3.891363651273732*^9, 
  3.89136365172295*^9}},ExpressionUUID->"05c73dba-4f12-4529-a59b-\
a38cdafe92f5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPhi]in", "[", 
    RowBox[{"r_", ",", "\[Theta]_"}], "]"}], ":=", 
   RowBox[{"\[Delta]1", " ", "r", " ", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPhi]mid", "[", 
    RowBox[{"r_", ",", "\[Theta]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Beta]1", "+", 
      FractionBox["\[Gamma]1", 
       SuperscriptBox["r", "3"]]}], ")"}], " ", "r", " ", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPhi]out", "[", 
    RowBox[{"r_", ",", "\[Theta]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "H0"}], "+", 
      FractionBox["\[Alpha]1", 
       SuperscriptBox["r", "3"]]}], ")"}], " ", "r", " ", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8913637084080915`*^9, 3.8913637509071693`*^9}, {
  3.891363794883004*^9, 3.891363801078191*^9}},
