4cf152a51815"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"soln", "=", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{"eqns", ",", 
     RowBox[{"{", 
      RowBox[{
      "\[Alpha]1", ",", "\[Beta]1", ",", "\[Gamma]1", ",", "\[Delta]1"}], 
      "}"}]}], "]"}], "//", "FullSimplify"}]}]], "Input",
