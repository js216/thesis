      {
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]},
      {
       RowBox[{"Cos", "[", "\[Phi]", "]"}]},
      {"0"}
     }], ")"}]}], ";"}]}], "Input",
