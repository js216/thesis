  "4/24/23 14:48:23 \
Out[27]=",ExpressionUUID->"b346e682-0df7-45a7-9965-36e40fd8a0cb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Uout2", "=", 
  RowBox[{"2", "\[Pi]", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "R2", "\[Infinity]"], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"Norm", "[", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"B0", 
                 RowBox[{"(", GridBox[{
                    {"0"},
                    {"0"},
                    {"1"}
                   }], ")"}]}], "+", 
                RowBox[{"Bout", "[", 
                 RowBox[{"r", ",", "\[Theta]", ",", "R1", ",", "M1"}], "]"}], 
                "+", 
                RowBox[{"Bout", "[", 
                 RowBox[{"r", ",", "\[Theta]", ",", "R2", ",", "M2"}], 
                 "]"}]}], ")"}], "]"}], "2"], "-", 
            SuperscriptBox["B0", "2"]}], "//", "Simplify"}], ")"}], ")"}], 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}], ")"}], 
     SuperscriptBox["r", "2"], 
     RowBox[{"\[DifferentialD]", "r"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.891100795318626*^9, 3.8911008221965275`*^9}, {
   3.891100984111974*^9, 3.891100985087809*^9}, 3.8911017238570776`*^9},
