Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"min", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Solve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"Uin2", "+", "Uout2", "+", " ", 
             RowBox[{"Umid2", "/", "\[Mu]r"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"{", 
              RowBox[{"M1", ",", "M2"}], "}"}], "}"}]}], "]"}], "//", 
          "FullSimplify"}], ")"}], "\[Equal]", "0"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"M1", ",", "M2"}], "}"}]}], "\[IndentingNewLine]", "]"}], "//",
      "FullSimplify"}], ")"}], "[", 
