Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Uout", "[", 
   RowBox[{"R_", ",", "M_"}], "]"}], "=", 
  RowBox[{"2", "\[Pi]", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "R", "\[Infinity]"], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"Norm", "[", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"B0", 
                 RowBox[{"(", GridBox[{
                    {"0"},
                    {"0"},
                    {"1"}
                   }], ")"}]}], "+", 
                RowBox[{"Bout", "[", 
                 RowBox[{"r", ",", "\[Theta]", ",", "R", ",", "M"}], "]"}]}], 
               ")"}], "]"}], "2"], "-", 
            SuperscriptBox["B0", "2"]}], "//", "Simplify"}], ")"}], ")"}], 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}], ")"}], 
     SuperscriptBox["r", "2"], 
     RowBox[{"\[DifferentialD]", "r"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.8910985595660725`*^9, 3.891098581721303*^9}, {
   3.8910987236363096`*^9, 3.8910987887363586`*^9}, {3.8910988211057353`*^9, 
