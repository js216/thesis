  "4/24/23 14:48:23 \
In[28]:=",ExpressionUUID->"d496a7da-06d3-410b-978f-74a52eba63d2"],

Cell[BoxData[
 FractionBox[
  RowBox[{"8", " ", "\[Pi]", " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"M1", " ", 
       SuperscriptBox["R1", "3"]}], "+", 
      RowBox[{"M2", " ", 
       SuperscriptBox["R2", "3"]}]}], ")"}], "2"], " ", 
