Cell[CellGroupData[{

Cell["Minimize energy in Mathematica", "Subsubsection",
 CellChangeTimes->{{3.891098845796076*^9, 
  3.8910988587395163`*^9}},ExpressionUUID->"463af795-210e-42f5-8b5c-\
3b8a08eb4ce4"],

Cell[BoxData[
 RowBox[{"$Assumptions", ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"Im", "[", "B0", "]"}], "==", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "M", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{"\[Mu]0", ">", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "\[Theta]", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "r", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "\[Phi]", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{"R", ">", "0"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.8910984995237756`*^9, 3.891098523888976*^9}, {
  3.8910985887463737`*^9, 3.8910986172640443`*^9}, {3.891098797321643*^9, 
  3.8910988007713575`*^9}},
 CellLabel->
  "4/24/23 14:48:21 \
In[15]:=",ExpressionUUID->"17664875-bdf6-4eed-ad9f-80c0457cc925"],

Cell["The unit vectors in spherical coordinates are", "Text",
 CellChangeTimes->{{3.8910981310314083`*^9, 
  3.891098141276823*^9}},ExpressionUUID->"0d086c59-0663-4e9c-8409-\
e2deaa51dce6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"rhat", "=", 
   RowBox[{"(", GridBox[{
      {
       RowBox[{
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}]},
      {
       RowBox[{
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]},
      {
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]hat", "=", 
   RowBox[{"(", GridBox[{
      {
       RowBox[{
        RowBox[{"Cos", "[", "\[Theta]", "]"}], 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}]},
      {
       RowBox[{
        RowBox[{"Cos", "[", "\[Theta]", "]"}], 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]},
      {
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Phi]hat", "=", 
   RowBox[{"(", GridBox[{
      {
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]},
      {
       RowBox[{"Cos", "[", "\[Phi]", "]"}]},
      {"0"}
     }], ")"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8910895983765736`*^9, 3.8910896313635483`*^9}, {
  3.8910897182956386`*^9, 3.891089772005818*^9}},
 CellLabel->
  "4/24/23 14:48:21 \
In[16]:=",ExpressionUUID->"dda7c098-557d-4387-b027-fda92849c2c4"],

Cell[TextData[{
 "The magnetic field inside and outside (at a position ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", ",", "\[Theta]"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "5555b1f0-7353-41dd-ba3b-0f63fd92e84b"],
 ") a sphere of radius ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "065658b4-c1c5-4f76-b412-a688bafb8256"],
 " and magnetization ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "d4898e62-e300-4909-ac8d-4af5b2a65b28"],
 " is"
}], "Text",
 CellChangeTimes->{{3.8910982212799215`*^9, 3.8910982734273214`*^9}, {
  3.89109833901785*^9, 
  3.8910983502097178`*^9}},ExpressionUUID->"2f9810fa-ab03-42a9-84bf-\
b609588df8b7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Bin", "[", "M_", "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{"2", "\[Mu]0"}], "3"], 
   RowBox[{"(", GridBox[{
      {"0"},
      {"0"},
      {"M"}
     }], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Bout", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", "R_", ",", "M_"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{"\[Mu]0", " ", 
     SuperscriptBox["R", "3"]}], 
    RowBox[{"3", 
     SuperscriptBox["r", "3"]}]], "M", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], "rhat"}], "+", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "\[Theta]hat"}]}], 
    ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.8910982426104345`*^9, 3.891098391499092*^9}},
 CellLabel->
  "4/24/23 14:48:21 \
In[19]:=",ExpressionUUID->"ed183ac1-6236-4c3a-a2ae-49958ab616fc"],

Cell[TextData[{
 "The total (integrated) magnetic energy inside and outside the sphere, when \
placed in an external constant field ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "0"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "4ceddc82-0dcb-47ae-a835-d77e7b822ab1"],
 ", is proportional to (subtract the constant ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["B", "0"], "2"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "469da2ac-ea86-482d-83d0-1f7bb9ff0bd3"],
 " contribution)"
}], "Text",
