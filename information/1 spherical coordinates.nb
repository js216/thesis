  3.8910988082092752`*^9}},ExpressionUUID->"30c92811-ecec-4f2b-afef-\
c30561c97aaa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Uin", "[", 
   RowBox[{"R_", ",", "M_"}], "]"}], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"4", "\[Pi]", " ", 
      SuperscriptBox["R", "3"]}], "3"], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"Norm", "[", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"B0", 
           RowBox[{"(", GridBox[{
              {"0"},
              {"0"},
              {"1"}
             }], ")"}]}], "+", 
          RowBox[{"Bin", "[", "M", "]"}]}], ")"}], "]"}], "2"], "-", 
      SuperscriptBox["B0", "2"]}], ")"}]}], "//", "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.8910984260672607`*^9, 3.8910984929285717`*^9}, {
  3.891098528272312*^9, 3.891098542121434*^9}, {3.8910986695724463`*^9, 
  3.8910986784891815`*^9}, {3.8910987129294257`*^9, 3.891098718180256*^9}, {
