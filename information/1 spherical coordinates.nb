Cell[CellGroupData[{

Cell["Two shells", "Subsubsection",
 CellChangeTimes->{{3.891100716968015*^9, 
  3.891100718893939*^9}},ExpressionUUID->"328e86f3-0a86-4aa6-966e-\
1e020160b9ed"],

Cell[BoxData[
 RowBox[{"$Assumptions", ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"Im", "[", "B0", "]"}], "==", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "M1", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "M2", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{"\[Mu]0", ">", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "\[Theta]", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "r", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{
     RowBox[{"Im", "[", "\[Phi]", "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{"R1", ">", "0"}], ",", 
    RowBox[{"R2", ">", "0"}], ",", " ", 
    RowBox[{"R1", "<", "R2"}], ",", 
    RowBox[{"\[Mu]r", "\[GreaterEqual]", "0"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.8910984995237756`*^9, 3.891098523888976*^9}, {
   3.8910985887463737`*^9, 3.8910986172640443`*^9}, {3.891098797321643*^9, 
