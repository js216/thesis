  "4/24/23 14:48:23 \
In[26]:=",ExpressionUUID->"a55555b7-e4db-4451-91ef-3e0e35665222"],

Cell[TextData[{
 "Now consider two concentric shells with radii ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R1", ",", "R2"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "127e55b6-5c40-49c3-b861-486a6ea602a7"],
 " and magnetizations ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M1", ",", "M2"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "efd5f5ab-c950-41ba-85ac-6abe7b39354b"],
 ". The energy inside and outside the two shells is"
}], "Text",
 CellChangeTimes->{{3.891100909360615*^9, 3.891100921563507*^9}, {
  3.8911014795143585`*^9, 
  3.8911015022548895`*^9}},ExpressionUUID->"788b7831-6d2d-4cd5-9989-\
69358ff9f779"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Uin2", "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"4", "\[Pi]", " ", 
      SuperscriptBox["R1", "3"]}], "3"], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"Norm", "[", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"B0", 
           RowBox[{"(", GridBox[{
              {"0"},
              {"0"},
              {"1"}
             }], ")"}]}], "+", 
          RowBox[{"Bin", "[", "M1", "]"}], "+", 
          RowBox[{"Bin", "[", "M2", "]"}]}], ")"}], "]"}], "2"], "-", 
      SuperscriptBox["B0", "2"]}], ")"}]}], "//", "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.891100727870264*^9, 3.8911007647730684`*^9}, 
   3.891101720530221*^9},
 CellLabel->
  "4/24/23 14:48:23 \
In[27]:=",ExpressionUUID->"39824a1f-785b-49c5-8849-7eb526ee56d9"],

Cell[BoxData[
 RowBox[{
  FractionBox["16", "27"], " ", 
  RowBox[{"(", 
   RowBox[{"M1", "+", "M2"}], ")"}], " ", "\[Pi]", " ", 
  SuperscriptBox["R1", "3"], " ", "\[Mu]0", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"3", " ", "B0"}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"M1", "+", "M2"}], ")"}], " ", "\[Mu]0"}]}], ")"}]}]], "Output",
 CellChangeTimes->{{3.8911007663926497`*^9, 3.891100784073161*^9}, 
   3.8911008404444714`*^9, 3.891101754338995*^9, 3.891112095048441*^9, 
   3.8913543693820457`*^9, 3.891354447876255*^9, 3.891354503410038*^9},
